{
  "profiles": [
    {
      "id": "production",
      "name": "Production Analysis",
      "description": "Strict analysis profile for production code",
      "severity": "strict",
      "checks": {
        "security": {
          "enabled": true,
          "level": "critical",
          "reportSeverity": true
        },
        "performance": {
          "enabled": true,
          "level": "high",
          "reportSeverity": true
        },
        "complexity": {
          "enabled": true,
          "maxCyclomatic": 8,
          "maxNesting": 3
        },
        "coverage": {
          "enabled": true,
          "minThreshold": 85
        },
        "documentation": {
          "enabled": true,
          "required": true
        },
        "typing": {
          "enabled": true,
          "strict": true
        }
      }
    },
    {
      "id": "development",
      "name": "Development Analysis",
      "description": "Relaxed analysis profile for development work",
      "severity": "relaxed",
      "checks": {
        "security": {
          "enabled": true,
          "level": "high",
          "reportSeverity": false
        },
        "performance": {
          "enabled": true,
          "level": "medium",
          "reportSeverity": false
        },
        "complexity": {
          "enabled": true,
          "maxCyclomatic": 12,
          "maxNesting": 5
        },
        "coverage": {
          "enabled": true,
          "minThreshold": 70
        },
        "documentation": {
          "enabled": false,
          "required": false
        },
        "typing": {
          "enabled": true,
          "strict": false
        }
      }
    },
    {
      "id": "ci-pipeline",
      "name": "CI Pipeline Analysis",
      "description": "Automated checks for continuous integration",
      "severity": "strict",
      "checks": {
        "security": {
          "enabled": true,
          "level": "critical"
        },
        "performance": {
          "enabled": false
        },
        "complexity": {
          "enabled": true,
          "maxCyclomatic": 10
        },
        "coverage": {
          "enabled": true,
          "minThreshold": 80,
          "failUnderThreshold": true
        },
        "documentation": {
          "enabled": true,
          "checkApiDocs": true
        },
        "typing": {
          "enabled": true,
          "strict": true
        },
        "linting": {
          "enabled": true,
          "treatWarningsAsErrors": false
        }
      }
    },
    {
      "id": "security-audit",
      "name": "Security Audit",
      "description": "Deep security analysis profile",
      "severity": "critical",
      "checks": {
        "security": {
          "enabled": true,
          "level": "critical",
          "deepScan": true,
          "includeTransitives": true
        },
        "secretScanning": {
          "enabled": true,
          "entropy": true,
          "patterns": true,
          "regex": true
        },
        "dependencies": {
          "enabled": true,
          "checkVulnerabilities": true,
          "checkLicenses": true,
          "checkOutdated": true
        },
        "codeInjection": {
          "enabled": true,
          "sqlInjection": true,
          "commandInjection": true,
          "xss": true,
          "xxe": true
        },
        "cryptography": {
          "enabled": true,
          "checkWeakAlgorithms": true,
          "checkHardcodedKeys": true
        }
      }
    },
    {
      "id": "performance-tuning",
      "name": "Performance Tuning",
      "description": "Focus on performance optimization and profiling",
      "severity": "medium",
      "checks": {
        "performance": {
          "enabled": true,
          "level": "critical",
          "profiling": true,
          "algorithms": true,
          "dataStructures": true
        },
        "memory": {
          "enabled": true,
          "leakDetection": true,
          "optimization": true
        },
        "concurrency": {
          "enabled": true,
          "deadlocks": true,
          "raceConditions": true
        },
        "database": {
          "enabled": true,
          "nPlusOne": true,
          "indexing": true,
          "queries": true
        }
      }
    },
    {
      "id": "documentation",
      "name": "Documentation Check",
      "description": "Verify documentation completeness and quality",
      "severity": "medium",
      "checks": {
        "documentation": {
          "enabled": true,
          "required": true,
          "checkApiDocs": true,
          "checkExamples": true,
          "checkDeprecations": true,
          "minLength": 50
        },
        "typingDocs": {
          "enabled": true,
          "requireReturnType": true,
          "requireParamType": true
        },
        "coverage": {
          "docstringCoverage": true,
          "minThreshold": 90
        }
      }
    }
  ],
  "rulesets": [
    {
      "id": "adrion-core-rules",
      "name": "ADRION Core Rules",
      "description": "Custom rules for ADRION 369 project",
      "rules": [
        {
          "id": "no-hardcoded-secrets",
          "name": "No Hardcoded Secrets",
          "severity": "error",
          "pattern": "(password|api_key|secret|token|credential)\\s*=\\s*['\"]",
          "message": "Hardcoded secrets detected. Use environment variables instead.",
          "languages": ["python", "go", "typescript"]
        },
        {
          "id": "no-console-logging",
          "name": "No Console Logging in Production",
          "severity": "warning",
          "pattern": "print\\(|console\\.log\\(",
          "message": "Console logging detected. Use proper logging framework.",
          "languages": ["python", "typescript"]
        },
        {
          "id": "guardian-laws-check",
          "name": "Guardian Laws Compliance",
          "severity": "error",
          "description": "Ensure code complies with 9 Guardian Laws",
          "checks": [
            "G1-Unity",
            "G2-Harmony",
            "G3-Rhythm",
            "G4-Causality",
            "G5-Transparency",
            "G6-Authenticity",
            "G7-Privacy",
            "G8-Nonmaleficence",
            "G9-Sustainability"
          ],
          "languages": ["python", "go"]
        },
        {
          "id": "proper-error-handling",
          "name": "Proper Error Handling",
          "severity": "warning",
          "pattern": "except:|catch\\s*\\(|try\\s*\\{",
          "message": "Ensure proper error handling and logging.",
          "languages": ["python", "go", "typescript"]
        },
        {
          "id": "sql-injection-prevention",
          "name": "SQL Injection Prevention",
          "severity": "error",
          "pattern": "execute\\(f\\\".*SELECT|execute\\(string\\.Format.*SELECT",
          "message": "Potential SQL injection. Use parameterized queries.",
          "languages": ["python", "go"]
        },
        {
          "id": "mapi-version-check",
          "name": "ADRION MCP Version Check",
          "severity": "warning",
          "description": "Verify MCP server version compatibility",
          "check": "mcp_version >= 1.0",
          "languages": ["python"]
        },
        {
          "id": "deployment-ready-check",
          "name": "Deployment Ready Certification",
          "severity": "error",
          "description": "Code must pass all deployment ready checks",
          "checks": [
            "unit-tests-pass",
            "coverage-above-80",
            "security-scan-clean",
            "no-deprecated-warnings"
          ],
          "languages": ["python", "go"]
        },
        {
          "id": "async-await-best-practices",
          "name": "Async/Await Best Practices",
          "severity": "warning",
          "pattern": "async def|async function",
          "message": "Ensure proper error handling and timeouts for async code.",
          "languages": ["python", "typescript"]
        },
        {
          "id": "type-hints-required",
          "name": "Type Hints Required",
          "severity": "warning",
          "description": "All public functions must have type hints",
          "pattern": "^\\s*def\\s+\\w+\\(.*\\)\\s*:",
          "message": "Function missing type hints",
          "languages": ["python"]
        },
        {
          "id": "naming-conventions",
          "name": "Naming Conventions",
          "severity": "warning",
          "description": "Enforce ADRION naming standards",
          "rules": [
            "Classes: PascalCase",
            "Functions: snake_case",
            "Constants: UPPER_SNAKE_CASE",
            "Private: _leading_underscore"
          ],
          "languages": ["python", "go"]
        }
      ]
    }
  ]
}
