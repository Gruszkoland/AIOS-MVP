#!/bin/sh
# ADRION 369 — Git pre-commit hook
# Install: copy this file to .git/hooks/pre-commit (chmod +x)
# Or run: python scripts/install_hooks.py

cd "$(git rev-parse --show-toplevel)" || exit 1

echo "▶  Running ADRION 369 pre-commit checks..."

python scripts/pre_commit_check.py
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌  Commit blocked. Fix the errors above and try again."
    echo "    To skip (NOT recommended): git commit --no-verify"
    exit 1
fi

exit 0
