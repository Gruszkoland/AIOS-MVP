        "query": "INSERT INTO email_log (lead_id, email_from, reply_body, classification, created_date) VALUES (?, ?, ?, ?, DATE('now'))",
        "parameterMode": "fromInput",
        "parameters": {
          "param1": "{{ $node['Node_Get_Ready_To_Email'].json.id }}",
          "param2": "{{ $node['Node_Monitor_Replies'].json.sender }}",
          "param3": "{{ $node['Node_Monitor_Replies'].json.snippet }}",
          "param4": "{{ $node['Node_Classify_Reply'].json.class }}"
        }
      },
      "id": "Node_Log_Reply",
      "name": "💾 Log Reply",
      "type": "n8n-nodes-base.sqlite",
      "typeVersion": 1,
