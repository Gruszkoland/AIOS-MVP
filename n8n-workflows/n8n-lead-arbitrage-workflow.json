        2500,
        200
      ]
    },
    {
      "parameters": {
        "trigger": "onNewEmail",
        "folderName": "[Gmail]/All Mail",
        "markAsRead": false
      },
      "id": "Node_Monitor_Replies",
      "name": "📬 Monitor: Check Replies",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [
        2700,
        200
      ],
      "credentials": {
        "gmailOAuth2": "YourGmailCredentials"
      }
    },
    {
      "parameters": {
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "method": "POST",
        "body": {
          "contentType": "application/json",
          "body": "{\n  \"model\": \"openai/gpt-3.5-turbo\",\n  \"temperature\": 0.2,\n  \"max_tokens\": 50,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Classify email reply as ONE of: [Interested, Not Interested, Out of Office, Question, Other]. Output JSON: {\\\"class\\\": string, \\\"confidence\\\": int}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $node['Node_Monitor_Replies'].json.snippet }}\"\n    }\n  ]\n}"
        }
      },
      "id": "Node_Classify_Reply",
      "name": "🤖 Classify: Email Response Type",
