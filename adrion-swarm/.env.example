# adrion-swarm secrets — copy to .env and fill in real values
# NEVER commit .env to git

# Shared PostgreSQL + healer password (min 20 random chars)
ADRION_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# n8n web admin password (min 20 random chars)
N8N_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# n8n license key (from n8n.io account)
N8N_LICENSE_KEY=CHANGE_ME_YOUR_LICENSE_KEY
