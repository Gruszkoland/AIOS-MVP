{
  "severities": {
    "error": 100,
    "critical": 90,
    "warning": 50,
    "info": 10,
    "hint": 5
  },
  "rules": {
    "security": [
      {
        "id": "SEC-001",
        "name": "Hardcoded Secrets Detection",
        "pattern": "(password|secret|api_key|token|credential)\\s*=\\s*['\\\"].*['\\\"]",
        "replacement": "$1 = os.getenv('$1_ENV_VAR')",
        "severity": "error",
        "languages": ["python"],
        "description": "Detects hardcoded secrets and suggests environment variable usage"
      },
      {
        "id": "SEC-002",
        "name": "SQL Injection Vulnerability",
        "pattern": "execute\\(f\\\".*\\{.*\\}.*SELECT|execute\\(string\\.Format.*SELECT",
        "severity": "critical",
        "languages": ["python", "go"],
        "description": "Detects raw SQL with unparameterized user input"
      },
      {
        "id": "SEC-003",
        "name": "Unvalidated User Input",
        "pattern": "request\\.args\\[|request\\.form\\[|request\\.json\\[",
        "severity": "warning",
        "languages": ["python"],
        "description": "User input should be validated and sanitized"
      },
      {
        "id": "SEC-004",
        "name": "Weak Cryptography",
        "pattern": "md5|hash\\.md5|hashlib\\.md5",
        "replacement": "use hashlib.sha256 instead",
        "severity": "error",
        "languages": ["python"],
        "description": "MD5 is cryptographically weak, use SHA256"
      },
      {
        "id": "SEC-005",
        "name": "Missing HTTPS Enforcement",
        "pattern": "http://",
        "severity": "warning",
        "languages": ["python", "typescript"],
        "description": "External URLs should use HTTPS"
      },
      {
        "id": "SEC-006",
        "name": "Insecure Deserialization",
        "pattern": "pickle\\.load|pickle\\.loads",
        "severity": "critical",
        "languages": ["python"],
        "description": "pickle is unsafe, use json or msgpack"
      },
      {
        "id": "SEC-007",
        "name": "Missing Authentication",
        "pattern": "@app\\.route|@router\\.get",
        "advice": "Ensure endpoints are protected with authentication",
        "severity": "warning",
        "languages": ["python"],
        "description": "Public endpoints should have authentication"
      },
      {
        "id": "SEC-008",
        "name": "OAuth Scope Validation",
        "pattern": "scope|Scope|SCOPE|api_key|API_KEY|Authorization",
        "advice": "Verify OAuth scopes follow least privilege principle (G7-Privacy)",
        "severity": "warning",
        "languages": ["python", "go", "typescript"],
        "description": "OAuth scopes should be granular and minimal per Guardian Law G7"
      },
      {
        "id": "SEC-009",
        "name": "Missing Token Rotation",
        "pattern": "access_token|refresh_token|token.*=",
        "advice": "Implement token rotation strategy, expire tokens appropriately",
        "severity": "warning",
        "languages": ["python", "go"],
        "description": "Tokens should be rotated and have expiration policies"
      },
      {
        "id": "SEC-010",
        "name": "Unencrypted Token Storage",
        "pattern": "token.*=.*os\\.getenv|Bearer.*token|Authorization.*Bearer",
        "advice": "Store tokens in secure, encrypted storage (e.g., keyring, secrets backend)",
        "severity": "error",
        "languages": ["python", "go"],
        "description": "Tokens must not be stored in plain text"
      },
      {
        "id": "SEC-011",
        "name": "Missing Scope Audit Logging",
        "pattern": "def.*oauth|def.*authenticate|def.*authorize",
        "advice": "Log all OAuth scope requests and grants for audit trail (G5-Transparency)",
        "severity": "warning",
        "languages": ["python", "go"],
        "description": "Every OAuth permission grant must be logged"
      },
      {
        "id": "SEC-012",
        "name": "Application Data Folder Leakage",
        "pattern": "\\.cache/|\\.hidden/|app_data|appdata",
        "advice": "Ensure hidden app data complies with privacy policy (G7-Privacy)",
        "severity": "warning",
        "languages": ["python"],
        "description": "Application data folders should be documented and user-deletable"
      }
    ],
    "performance": [
      {
        "id": "PERF-001",
        "name": "N+1 Query Problem",
        "pattern": "for .* in .*:\\s*.*\\.query|for .* in .*:\\s*db\\.session\\.query",
        "severity": "warning",
        "languages": ["python"],
        "description": "Potential N+1 query detected. Use eager loading or joins"
      },
      {
        "id": "PERF-002",
        "name": "Inefficient String Concatenation",
        "pattern": "\\+\\s*\\+|\\+=.*\\+",
        "replacement": "use str.join() or f-strings",
        "severity": "warning",
        "languages": ["python"],
        "description": "Use str.join() instead of += for multiple concatenations"
      },
      {
        "id": "PERF-003",
        "name": "Large Loops Without Break",
        "pattern": "for .* in range\\(\\d{4,}\\)|for .* in .*range\\(\\d{4,}\\)",
        "severity": "info",
        "languages": ["python"],
        "description": "Consider if this large loop is necessary"
      },
      {
        "id": "PERF-004",
        "name": "Unindexed Database Query",
        "pattern": "\\.filter\\(.*==.*\\)",
        "advice": "Ensure the filter column is indexed",
        "severity": "info",
        "languages": ["python"],
        "description": "Database filters should use indexed columns"
      },
      {
        "id": "PERF-005",
        "name": "Synchronous Operations in Async",
        "pattern": "sleep|time\\.sleep|blocking_call",
        "severity": "warning",
        "languages": ["python", "typescript"],
        "description": "Blocking operations in async code defeat concurrency"
      }
    ],
    "complexity": [
      {
        "id": "COMPLEX-001",
        "name": "High Cyclomatic Complexity",
        "threshold": 10,
        "severity": "warning",
        "languages": ["python", "go"],
        "description": "Function complexity exceeds recommended threshold"
      },
      {
        "id": "COMPLEX-002",
        "name": "Deep Nesting",
        "threshold": 4,
        "severity": "warning",
        "languages": ["python", "go", "typescript"],
        "description": "Excessive nesting reduces code readability"
      },
      {
        "id": "COMPLEX-003",
        "name": "Large Function",
        "threshold": 200,
        "severity": "info",
        "languages": ["python", "go"],
        "description": "Function exceeds recommended line count"
      },
      {
        "id": "COMPLEX-004",
        "name": "God Object",
        "threshold": 500,
        "severity": "warning",
        "languages": ["python", "go"],
        "description": "Class is too large and does too much"
      }
    ],
    "quality": [
      {
        "id": "QUAL-001",
        "name": "Missing Docstring",
        "pattern": "^\\s*(def|class)\\s+\\w+\\(.*\\):\\s*$",
        "severity": "warning",
        "languages": ["python"],
        "description": "Public functions/classes should have docstrings"
      },
      {
        "id": "QUAL-002",
        "name": "Missing Type Hints",
        "pattern": "def\\s+\\w+\\([^)]*\\)\\s*->",
        "negative": true,
        "severity": "warning",
        "languages": ["python"],
        "description": "Public functions should have type hints"
      },
      {
        "id": "QUAL-003",
        "name": "Unused Imports",
        "severity": "info",
        "languages": ["python", "go", "typescript"],
        "description": "Remove unused import statements"
      },
      {
        "id": "QUAL-004",
        "name": "Magic Numbers",
        "pattern": "\\b\\d{3,}\\b(?!e-|e\\+|\\d{2})",
        "severity": "info",
        "languages": ["python", "go"],
        "description": "Replace magic numbers with named constants"
      },
      {
        "id": "QUAL-005",
        "name": "Inconsistent Naming",
        "severity": "warning",
        "languages": ["python", "go"],
        "description": "Function names should use consistent conventions"
      }
    ],
    "testing": [
      {
        "id": "TEST-001",
        "name": "Missing Unit Tests",
        "description": "No unit tests found for this module",
        "severity": "warning",
        "languages": ["python"]
      },
      {
        "id": "TEST-002",
        "name": "Low Test Coverage",
        "threshold": 80,
        "severity": "warning",
        "languages": ["python"],
        "description": "Test coverage below recommended threshold"
      },
      {
        "id": "TEST-003",
        "name": "Test Without Assertions",
        "pattern": "def test_.*\\(.*\\):\\s*$",
        "severity": "error",
        "languages": ["python"],
        "description": "Test functions must have assertions"
      }
    ],
    "adrion-specific": [
      {
        "id": "ADRION-001",
        "name": "Guardian Laws Violation",
        "description": "Code violates one of the 9 Guardian Laws",
        "severity": "critical",
        "laws": [
          "G1-Unity",
          "G2-Harmony",
          "G3-Rhythm",
          "G4-Causality",
          "G5-Transparency",
          "G6-Authenticity",
          "G7-Privacy",
          "G8-Nonmaleficence",
          "G9-Sustainability"
        ]
      },
      {
        "id": "ADRION-002",
        "name": "Missing Agent Health Check",
        "pattern": "class.*Agent|def.*agent",
        "advice": "Agent must implement health monitoring",
        "severity": "warning",
        "languages": ["python"]
      },
      {
        "id": "ADRION-003",
        "name": "Trust Score Not Updated",
        "pattern": "class.*Agent",
        "advice": "Agent must update trust score on completion",
        "severity": "warning",
        "languages": ["python"]
      },
      {
        "id": "ADRION-004",
        "name": "Genesis Record Not Logged",
        "pattern": "def.*execute|async def.*execute",
        "advice": "Operation must be logged to Genesis Record",
        "severity": "warning",
        "languages": ["python"]
      }
    ]
  },
  "fixers": [
    {
      "id": "fix-hardcoded-secret",
      "ruleId": "SEC-001",
      "description": "Convert hardcoded secret to environment variable",
      "enabled": true
    },
    {
      "id": "fix-weak-hash",
      "ruleId": "SEC-004",
      "description": "Replace MD5 with SHA256",
      "enabled": true
    },
    {
      "id": "fix-string-concat",
      "ruleId": "PERF-002",
      "description": "Convert string concatenation to join",
      "enabled": true
    },
    {
      "id": "fix-unused-imports",
      "ruleId": "QUAL-003",
      "description": "Remove unused imports",
      "enabled": true
    }
  ],
  "customPatterns": {
    "endpoints": "^@(app|router|server)\\.(get|post|put|delete|patch)\\(",
    "migrations": "^(CREATE|ALTER|DROP)\\s+(TABLE|INDEX|SCHEMA)",
    "envVars": "os\\.getenv\\(|process\\.env\\[",
    "logging": "logger\\.(info|error|warning|debug)\\(|log\\.\\w+\\("
  },
  "metadata": {
    "version": "1.0",
    "author": "ADRION-369",
    "created": "2026-04-08",
    "description": "Comprehensive rule set for ADRION 369 code analysis"
  }
}
