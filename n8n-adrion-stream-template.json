{
  "name": "ADRION 369 - Marketplace to Arbitrage Stream",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 4
            }
          ]
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "url": "https://api.your-marketplace.com/daily-events",
        "authentication": "headerAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_MARKET_TOKEN"
            }
          ]
        },
        "options": {}
      },
      "name": "Fetch Marketplace Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [400, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://your-adrion-server:8001/api/arbitrage/streams/run",
        "authentication": "headerAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_ADRION_TOKEN"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "dry_run",
              "value": "false"
            }
          ]
        }
      },
      "name": "Trigger ADRION Ingestion",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [650, 300]
    },
    {
      "parameters": {
        "content": "### n8n Integration Note\nADRION 369 will pull data from your environment variable URLs.\nThis node simply triggers the refresh cycle."
      },
      "name": "Documentation",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [150, 150]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Fetch Marketplace Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Marketplace Data": {
      "main": [
        [
          {
            "node": "Trigger ADRION Ingestion",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
