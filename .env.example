# ADRION 369 v1.0 - Environment Configuration
# Copy this to .env and fill in your actual values.
# NEVER commit .env to git.
# For offline/local mode copy .env.offline → .env instead.

# ── LLM Backend ────────────────────────────────────────────────────────────
# Options: auto | openrouter | openai | anthropic | mock
# "auto" selects based on which key is present (priority: openrouter > openai > anthropic > mock)
LLM_BACKEND=auto

# OpenRouter (recommended - free tier available at openrouter.ai)
OPENROUTER_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# Anthropic direct
ANTHROPIC_API_KEY=

# LLM model to use (any OpenRouter-supported model)
LLM_MODEL=openai/gpt-3.5-turbo

# ── Scraping ────────────────────────────────────────────────────────────────
# Apify API token (free tier: 5 USD/month credit)
# Get at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Business Rules ─────────────────────────────────────────────────────────
DAILY_BID_LIMIT=20
XRP_TARGET=1000
MIN_PROFIT_USD=30
MIN_ANALYZER_SCORE=7
MAX_EST_COST_PER_BID_USD=2.5
MAX_BIDS_PER_CLIENT_PER_DAY=1
MAX_DAILY_EST_COST_USD=25
UGC_EVENTS_DAILY_CAP=4
RESALE_EVENTS_DAILY_CAP=4

# Optional external stream connectors (n8n/marketplace webhooks)
UGC_SOURCE_URL=
RESALE_SOURCE_URL=
STREAMS_CONNECTOR_TOKEN=

# ── Quantum Bridge Protection (A-11 hardening) ────────────────────────────
# Rate limit for /api/arbitrage/quantum/* endpoints (per IP, sliding window)
QUANTUM_RATE_LIMIT_MAX=30
QUANTUM_RATE_LIMIT_WINDOW_SECONDS=60.0

# Circuit breaker for Go Sentinel bridge in arbitrage/quantum.py
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_SECONDS=30.0

# Runtime test target for Arbitrage API (avoids localhost routing ambiguity)
ARBITRAGE_API_BASE=http://127.0.0.1:8001

# ── Stable Non-Secret References ──────────────────────────────────────────
REFERENCE_CONTACT_EMAIL=punktodniesienia.adrian@gmail.com
STRIPE_DASHBOARD_TEST_URL=https://dashboard.stripe.com/acct_1TGXT6J5g6ZX7qxJ/test/dashboard

# ── Secret Placeholders (set ONLY in local .env / password manager) ───────
# Never commit real values for these variables.
STRIPE_LOGIN_EMAIL=
STRIPE_LOGIN_PASSWORD=
STRIPE_BACKUP_CODE=

# ── SECURITY NOTE ───────────────────────────────────────────────────────────
# XRP wallet address is NEVER stored here or anywhere in the codebase.
# You enter it manually when making transfers.
# XRP wallet: enter manually at time of transfer only.

# ── Database ─────────────────────────────────────────────────────────────────
# Options: sqlite | postgresql
DB_ENGINE=sqlite
SQLITE_DB_PATH=./arbitrage.db

# PostgreSQL (only needed when DB_ENGINE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=adrion
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=genesis_record
DATABASE_URL=postgresql://adrion:CHANGE_ME@localhost:5432/genesis_record

# Connection pool (PostgreSQL only)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONN_TIMEOUT=10
DB_CONN_RETRIES=3

# ── Services ──────────────────────────────────────────────────────────────────
# Arbitrage API
ARB_PORT=8001
ARBITRAGE_API_BASE=http://127.0.0.1:8001

# Admin panel (local web dashboard)
UAP_FRONTEND_PORT=8003
UAP_API_KEY=CHANGE_ME_LOCAL_KEY

# n8n Workflows
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD
N8N_PORT=5678

# Vortex Sentinel
VORTEX_PORT=1740

# ── Ollama (local LLM, offline-friendly) ──────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=120

# ── Health Monitoring ─────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL_SECONDS=30
SERVICE_RESTART_ATTEMPTS=5

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG_MODE=false

# ── Version & Project ─────────────────────────────────────────────────────────
VERSION=1.0.0
PROJECT_NAME=ADRION 369
ENVIRONMENT=production

# ── UAP Auth (Unified Admin Panel) ────────────────────────────────────────────
# REQUIRED in production. Min 32 random characters.
# PRIORITY 6 FIX: API key for Phase 2 endpoints (X-API-Key header validation)
UAP_API_KEY=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING

# JWT secret for authentication tokens
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING

# PRIORITY 4 FIX: HMAC secret for Dry Run Mode (DRM) approval tokens
# Prevents spoofing of destructive operations (git reset, file deletion)
DRM_HMAC_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING

MAPI_PORT=8002

# ── Nginx Reverse Proxy ───────────────────────────────────────────────────────
# Domain name for Nginx TLS certificate (e.g. adrion.local or your domain)
NGINX_SERVER_NAME=localhost
# TLS certs: place files at config/nginx/certs/adrion.crt and adrion.key
# For local dev: mkcert localhost  →  mv localhost.pem config/nginx/certs/adrion.crt
#                                     mv localhost-key.pem config/nginx/certs/adrion.key

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_ALERT_WEBHOOK_URL=http://alert-sink:8080/adrion-alert
