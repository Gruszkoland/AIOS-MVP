# ADRION 369 - Freelance Arbitrage Environment Configuration
# Copy this to .env and fill in your actual values.
# NEVER commit .env to git.

# ── LLM Backend ────────────────────────────────────────────────────────────
# Options: auto | openrouter | openai | anthropic | mock
# "auto" selects based on which key is present (priority: openrouter > openai > anthropic > mock)
LLM_BACKEND=auto

# OpenRouter (recommended - free tier available at openrouter.ai)
OPENROUTER_API_KEY=

# OpenAI direct
OPENAI_API_KEY=

# Anthropic direct
ANTHROPIC_API_KEY=

# LLM model to use (any OpenRouter-supported model)
LLM_MODEL=openai/gpt-3.5-turbo

# ── Scraping ────────────────────────────────────────────────────────────────
# Apify API token (free tier: 5 USD/month credit)
# Get at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── Business Rules ─────────────────────────────────────────────────────────
DAILY_BID_LIMIT=20
XRP_TARGET=1000
MIN_PROFIT_USD=30
MIN_ANALYZER_SCORE=7
MAX_EST_COST_PER_BID_USD=2.5
MAX_BIDS_PER_CLIENT_PER_DAY=1
MAX_DAILY_EST_COST_USD=25
UGC_EVENTS_DAILY_CAP=4
RESALE_EVENTS_DAILY_CAP=4

# Optional external stream connectors (n8n/marketplace webhooks)
UGC_SOURCE_URL=
RESALE_SOURCE_URL=
STREAMS_CONNECTOR_TOKEN=

# ── Stable Non-Secret References ──────────────────────────────────────────
REFERENCE_CONTACT_EMAIL=punktodniesienia.adrian@gmail.com
STRIPE_DASHBOARD_TEST_URL=https://dashboard.stripe.com/acct_1TGXT6J5g6ZX7qxJ/test/dashboard

# ── Secret Placeholders (set ONLY in local .env / password manager) ───────
# Never commit real values for these variables.
STRIPE_LOGIN_EMAIL=
STRIPE_LOGIN_PASSWORD=
STRIPE_BACKUP_CODE=

# ── SECURITY NOTE ───────────────────────────────────────────────────────────
# XRP wallet address is NEVER stored here or anywhere in the codebase.
# You enter it manually when making transfers.
# XRP wallet: enter manually at time of transfer only.
