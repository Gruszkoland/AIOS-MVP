# =============================================================================
# GitHub — zmienne środowiskowe (szablon)
# =============================================================================
# Skopiuj ten plik do `.env` w tym samym katalogu albo ustaw zmienne w systemie /
# sesji PowerShell. Nie zapisuj prawdziwych tokenów w plikach śledzonych przez Git.
#
# -----------------------------------------------------------------------------
# Co jest do czego (krótko)
# -----------------------------------------------------------------------------
# GITHUB_TOKEN — token Personal Access Token lub podobny; używany przez biblioteki
# i skrypty wywołujące REST/GraphQL GitHub API (zależnie od narzędzia).
#
# GH_TOKEN — ta sama klasa wartości co wyżej; CLI `gh` szuka w pierwszej kolejności
# GH_TOKEN, potem m.in. GITHUB_TOKEN. Wystarczy ustawić jedną zmienną, jeśli Twoje
# narzędzie na to pozwala — nie musisz duplikować wartości w dwóch kluczach.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GH_TOKEN=

# -----------------------------------------------------------------------------
# PowerShell — ustawianie wartości lokalnie
# -----------------------------------------------------------------------------
# Tylko bieżące okno terminala (po zamknięciu znika):
#   $env:GITHUB_TOKEN = "tu-wklej-token"
#   $env:GH_TOKEN = "tu-wklej-token"
#
# Trwałe dla Twojego konta Windows (nowe okna PowerShell po ponownym uruchomieniu):
#   setx GITHUB_TOKEN "tu-wklej-token"
#   setx GH_TOKEN "tu-wklej-token"
# Po `setx` zamknij terminal i otwórz nowy — zmienna nie pojawi się w tym samym oknie.
#
# -----------------------------------------------------------------------------
# Next.js (np. PROJEKTY/162 demencje w schemacie 369/dashboard/nextjs-dashboard/)
# -----------------------------------------------------------------------------
# Sekrety dostępne po stronie serwera zwykle umieszcza się w `.env.local` w katalogu
# samej aplikacji Next.js (ten plik jest ignorowany przez Git w tym repozytorium).
# Zmienne widoczne w przeglądarce muszą mieć prefiks NEXT_PUBLIC_ — nie używaj go
# dla tokenów ani haseł.
