{
  "mcpServers": {
    "router": {
      "command": "python",
      "args": ["-m", "mcp.servers.router"],
      "env": {
        "PORT": "9000",
        "ENVIRONMENT": "development",
        "LOG_LEVEL": "DEBUG"
      },
      "disabled": false
    },
    "vortex": {
      "command": "python",
      "args": ["-m", "mcp.servers.vortex"],
      "env": {
        "PORT": "9001",
        "PULSE_HZ": "174",
        "ENVIRONMENT": "development"
      },
      "disabled": false
    },
    "guardian": {
      "command": "python",
      "args": ["-m", "mcp.servers.guardian"],
      "env": {
        "PORT": "9002",
        "LAWS_CONFIG": "docs/GUARDIAN_LAWS_CANONICAL.json",
        "AUDIT_LOG": "logs/guardian_audit.jsonl"
      },
      "disabled": false
    },
    "oracle": {
      "command": "python",
      "args": ["-m", "mcp.servers.oracle"],
      "env": {
        "PORT": "9003",
        "SCORING_BASELINE": "config/oracle_baseline.json"
      },
      "disabled": false
    },
    "genesis": {
      "command": "python",
      "args": ["-m", "mcp.servers.genesis"],
      "env": {
        "PORT": "9004",
        "ARCHIVE_PATH": "Genesis Record",
        "IMMUTABLE_MODE": "true"
      },
      "disabled": false
    },
    "healer": {
      "command": "python",
      "args": ["-m", "mcp.servers.healer"],
      "env": {
        "PORT": "9005",
        "REPAIR_MODE": "auto",
        "HEALTH_CHECK_INTERVAL": "300"
      },
      "disabled": false
    }
  }
}
