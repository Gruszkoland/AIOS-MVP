    "**/.aider": false,
    "**/.git": false,
    "**/node_modules": true,
    "**/*.pyc": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    ".aider": false,
    "node_modules": true,
    ".git": true,
    "**/.venv": true,
    "cUsersadiha.1_Projekty/**": true,
    "**/Genesis Record/**": true,
    "**/90_ARCHIWUM/**": true,
    "**/__pycache__": true,
    "**/coverage": true,
    "**/htmlcov": true,
    "**/*.pyc": true
  },
  "search.useIgnoreFiles": true,
  "search.smartCase": true,
  "search.followSymlinks": false,
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/__pycache__/**": true,
    "**/node_modules/**": true,
    "**/cUsersadiha.1_Projekty/**": true,
    "**/Genesis Record/**": true,
    "**/90_ARCHIWUM/**": true,
    "**/.git/objects/**": true,
    "**/coverage/**": true,
    "**/htmlcov/**": true,
    "**/logs/**": true,
    "**/*.log": true,
    "**/htmlcov/**": true,
    "**/.pytest_cache/**": true,
    "**/.ruff_cache/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.mypy_cache/**": true
  },
  "files.maxMemoryForLargeFilesMB": 512,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  "workbench.colorTheme": "Material Theme High Contrast",
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.fetchOnPull": true,
  "git.pruneOnFetch": true,
  "git.showFetchOutput": false,
  "python.terminal.useEnvFile": true,
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.diagnosticMode": "all",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/arbitrage",
    "${workspaceFolder}/persona-agents",
    "${workspaceFolder}/scripts"
  ],
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "python.linting.pylintArgs": [
    "--disable=W0212,C0111",
    "--max-line-length=120"
  ],
  "python.formatting.provider": "black",
  "python.formatting.blackArgs": ["--line-length=120"],
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests",
    "--timeout=60",
    "-v",
    "--tb=short",
    "-x"
  ],
  "python.debugging.logToFile": true,
  "python.debugging.logDir": "${workspaceFolder}/.debug-logs",
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.automationProfile.windows": {
    "path": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
    "args": ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]
  },
  "terminal.integrated.env.windows": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "PYTHONPATH": "${workspaceFolder}",
    "ADRION_MODE": "development"
  },
  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.bufferSize": 5000,
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },
  "peacock.color": "#264653",
  "files.associations": {
    "**/config/personas.yml": "yaml",
    "**/aider/config.yml": "yaml"
  },
  "diffEditor.maxComputationTime": 0,
  "github.copilot.chat.codeGeneration.instructions": [
