  "roo.performance.enableParallelAnalysis": true,
  "roo.performance.cacheEnabled": true,
  "roo.performance.cachePath": ".roo_cache/",
  "roo.reporting.generateOnSave": true,
  "roo.reporting.reportFormat": ["json", "html"],
  "roo.reporting.reportPath": "reports/",
  "roo.advancedFeatures.enableAI": true,
  "roo.advancedFeatures.enableRefactoringSuggestions": true,
  "roo.advancedFeatures.enablePerformanceOptimizations": true,
  "roo.advancedFeatures.enableSecurityAdvisories": true,
  "roo.ignoreFile": ".roo.ignore",
  "roo.configFile": ".roo.json",
  "roo.profilesFile": "roo.profiles.json",
  "roo.rulesFile": "roo.rules.json",
  "roo.rcFile": ".roorc",
  "roo.mcp.configFile": ".roo/mcp.json",
