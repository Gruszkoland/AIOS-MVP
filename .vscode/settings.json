  "roo.guardrails.enforceDocumentation": true,
  "roo.ai.mode": "hybrid",
  "roo.ai.localEndpoint": "http://localhost:11434",
  "roo.ai.enableRefactoring": true,
  "roo.ai.enableOptimization": true,
  "roo.cache.enabled": true,
  "roo.cache.path": ".roo_cache/",
  "roo.cache.ttl": 86400,
  "roo.notifications.showComplete": true,
  "roo.notifications.showProblems": true,
  "roo.notifications.desktopNotifications": false,
  "roo.output.colorOutput": true,
  "roo.output.verbosity": "info",
  "roo.commands.onSave": true,
  "roo.commands.onOpen": true,
  "roo.integration.git.enabled": true,
  "roo.integration.docker.enabled": true,
  "roo.integration.kubernetes.enabled": true,
  "roo.architectureAnalysis.enabled": true,
  "roo.architectureAnalysis.detectPatterns": true,
  "roo.architectureAnalysis.generateDiagrams": true,
  "roo.qualityMetrics.trackComplexity": true,
  "roo.qualityMetrics.trackCoverage": true,
  "roo.qualityMetrics.trackSecurity": true,
  "roo.qualityMetrics.trackPerformance": true,
  "roo.security.oauthValidation": true,
  "roo.security.checkScopeGranularity": true,
  "roo.security.auditHiddenDataFolders": true,
  "roo.security.validateTokenRotation": true,
  "roo.security.enforceEncryptedTokenStorage": true,
  "roo.security.requireScopeAuditLogging": true,
  "roo.security.privacyCompliance": "G7-Privacy",
  "roo.security.nonmaleficenceCheck": "G8-Nonmaleficence",
  "roo.security.transparencyAudit": "G5-Transparency",
  "roo.oauth.enableScopeValidation": true,
  "roo.oauth.minimalScopeEnforcement": true,
  "roo.oauth.tokenExpirationHours": 24,
  "roo.oauth.refreshTokenRotation": true,
  "roo.oauth.auditLoggingEnabled": true,
  "roo.oauth.scopeDocumentation": "docs/oauth-scopes.md",
  "roo.oauth.tokenStorageBackend": "encrypted-env",
  "roo.encryption.atRest": true,
  "roo.encryption.algorithm": "AES-256-GCM",
  "roo.encryption.keyDerivation": "PBKDF2",
